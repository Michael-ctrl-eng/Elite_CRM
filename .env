# ═══════════════════════════════════════════════════
# Elite CRM - Environment Variables (MySQL)
# ═══════════════════════════════════════════════════

# ─── DATABASE (MySQL) ───
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# For local dev:
DATABASE_URL="mysql://root:password@localhost:3306/elite_crm"
# For Hostinger MySQL:
# DATABASE_URL="mysql://username:password@hostname:3306/elite_crm"
# For Vercel + PlanetScale/Neon:
# DATABASE_URL="mysql://user:pass@host/db?sslaccept=servercert"

# ─── NEXTAUTH ───
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="elite-crm-super-secret-key-change-in-production-2024"
JWT_SECRET="elite-jwt-secret-key-change-in-production-2024"

# ─── APP CONFIG ───
NEXT_PUBLIC_SIGNUP_ENABLED="false"
NEXT_PUBLIC_APP_NAME="Elite CRM"
NEXT_PUBLIC_DEMO_MODE="false"

# ─── SMTP (Email) ───
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_SENDER="noreply@yourdomain.com"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="changeme"
