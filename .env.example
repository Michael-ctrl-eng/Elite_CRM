# ═══════════════════════════════════════════════════
# Elite CRM - Vercel Environment Variables
# ═══════════════════════════════════════════════════
# Add ALL of these in Vercel → Project → Settings → Environment Variables

# ─── DATABASE (MySQL) ───
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@host:3306/database

# ─── NEXTAUTH ───
# Set to your production URL (e.g. https://crm.yourdomain.com)
NEXTAUTH_URL=https://your-domain.vercel.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-secret-with-openssl-rand-base64-32
JWT_SECRET=generate-another-secret-with-openssl-rand-base64-32

# ─── APP CONFIG ───
NEXT_PUBLIC_SIGNUP_ENABLED=false
NEXT_PUBLIC_APP_NAME=Elite CRM
NEXT_PUBLIC_DEMO_MODE=false

# ─── SMTP (Email) ───
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_SENDER=noreply@yourdomain.com
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
