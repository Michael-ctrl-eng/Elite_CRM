generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── SPACE (Tenant) ───

model Space {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  logo        String?  @db.Text
  industry    String?  @db.VarChar(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      SpaceMember[]
  deals        Deal[]
  todos        Todo[]
  meetings     Meeting[]
  prospects    Prospect[]
  customers    Customer[]
  companies    Company[]
  activityLogs ActivityLog[]
  invitations  Invitation[]
}

// ─── SPACE MEMBERSHIP ───

model SpaceMember {
  id       String   @id @default(cuid())
  userId   String   @db.VarChar(30)
  spaceId  String   @db.VarChar(30)
  role     String   @default("viewer") @db.VarChar(20) // admin | manager | viewer
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
}

// ─── USER ───

model User {
  id                String   @id @default(cuid()) @db.VarChar(30)
  email             String   @unique @db.VarChar(255)
  name              String?  @db.VarChar(255)
  password          String?  @db.VarChar(255)
  image             String?  @db.Text
  status            String   @default("Inactive") @db.VarChar(20) // Active | Inactive | Invite | Deleted
  globalRole        String   @default("viewer") @db.VarChar(20)   // superadmin | admin | manager | viewer
  isDemo            Boolean  @default(false)
  lastSeen          DateTime @default(now())
  verificationToken String?  @db.VarChar(255)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  spaceMemberships SpaceMember[]
  ownedDeals       Deal[]
  dealNotes        DealNote[]
  ownedTodos       Todo[]
  ownedMeetings    Meeting[]
  ownedProspects   Prospect[]
  ownedCustomers   Customer[]
  ownedCompanies   Company[]
  assignedTodos    Todo[]         @relation("AssignedTodos")
  assignedMeetings Meeting[]      @relation("AssignedMeetings")
  activityLogs     ActivityLog[]
  emailSetting     EmailSettings?
  accounts         Account[]
  sessions         Session[]
}

// ─── NEXTAUTH MODELS ───

model Account {
  id                String  @id @default(cuid()) @db.VarChar(30)
  userId            String  @db.VarChar(30)
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @db.VarChar(100)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @db.VarChar(30)
  sessionToken String   @unique @db.VarChar(255)
  userId       String   @db.VarChar(30)
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime

  @@unique([identifier, token])
}

// ─── DEAL ───

model Deal {
  id          String    @id @default(cuid()) @db.VarChar(30)
  title       String    @db.VarChar(255)
  value       Float?
  currency    String    @default("USD") @db.VarChar(10)
  stage       String    @default("New") @db.VarChar(50)
  probability Int?
  closeDate   DateTime?
  description String?   @db.Text
  notes       String?   @db.Text
  tags        String?   @db.Text
  source      String?   @db.VarChar(100)
  contactId   String?   @db.VarChar(30)
  companyId   String?   @db.VarChar(30)
  spaceId     String    @db.VarChar(30)
  ownerId     String    @db.VarChar(30)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  space   Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  owner   User     @relation(fields: [ownerId], references: [id])
  contact Customer? @relation(fields: [contactId], references: [id])
  company Company?  @relation(fields: [companyId], references: [id])
  dealNotes DealNote[]
}

// ─── DEAL NOTE ───

model DealNote {
  id        String   @id @default(cuid()) @db.VarChar(30)
  content   String   @db.Text
  dealId    String   @db.VarChar(30)
  userId    String   @db.VarChar(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

// ─── TODO ───

model Todo {
  id           String   @id @default(cuid()) @db.VarChar(30)
  title        String   @db.VarChar(255)
  description  String?  @db.Text
  notes        String?  @db.Text
  status       String   @default("Todo") @db.VarChar(30)
  priority     String   @default("Medium") @db.VarChar(20)
  dueDate      DateTime?
  tags         String?  @db.Text
  linkedTo     String?  @db.VarChar(100)
  assignedToId String?  @db.VarChar(30)
  spaceId      String   @db.VarChar(30)
  ownerId      String   @db.VarChar(30)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  space      Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  owner      User  @relation(fields: [ownerId], references: [id])
  assignedTo User? @relation("AssignedTodos", fields: [assignedToId], references: [id])
}

// ─── MEETING ───

model Meeting {
  id           String   @id @default(cuid()) @db.VarChar(30)
  title        String   @db.VarChar(255)
  description  String?  @db.Text
  notes        String?  @db.Text
  location     String?  @db.VarChar(255)
  status       String   @default("Scheduled") @db.VarChar(30)
  startDate    DateTime
  endDate      DateTime?
  recurrence   String?  @db.VarChar(50)
  tags         String?  @db.Text
  linkedTo     String?  @db.VarChar(100)
  assignedToId String?  @db.VarChar(30)
  spaceId      String   @db.VarChar(30)
  ownerId      String   @db.VarChar(30)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  space      Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  owner      User  @relation(fields: [ownerId], references: [id])
  assignedTo User? @relation("AssignedMeetings", fields: [assignedToId], references: [id])
}

// ─── PROSPECT ───

model Prospect {
  id        String   @id @default(cuid()) @db.VarChar(30)
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  company   String?  @db.VarChar(255)
  position  String?  @db.VarChar(100)
  source    String?  @db.VarChar(100)
  status    String   @default("New") @db.VarChar(30)
  value     Float?
  notes     String?  @db.Text
  tags      String?  @db.Text
  companyId String?  @db.VarChar(30)
  spaceId   String   @db.VarChar(30)
  ownerId   String   @db.VarChar(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space      Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  owner      User    @relation(fields: [ownerId], references: [id])
  companyRel Company? @relation(fields: [companyId], references: [id])
}

// ─── CUSTOMER ───

model Customer {
  id        String   @id @default(cuid()) @db.VarChar(30)
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  company   String?  @db.VarChar(255)
  position  String?  @db.VarChar(100)
  status    String   @default("Active") @db.VarChar(30)
  value     Float?
  notes     String?  @db.Text
  tags      String?  @db.Text
  address   String?  @db.Text
  companyId String?  @db.VarChar(30)
  spaceId   String   @db.VarChar(30)
  ownerId   String   @db.VarChar(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space      Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  owner      User    @relation(fields: [ownerId], references: [id])
  companyRel Company? @relation(fields: [companyId], references: [id])
  deals      Deal[]
}

// ─── COMPANY ───

model Company {
  id        String   @id @default(cuid()) @db.VarChar(30)
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  website   String?  @db.VarChar(255)
  industry  String?  @db.VarChar(100)
  status    String   @default("Active") @db.VarChar(30)
  notes     String?  @db.Text
  tags      String?  @db.Text
  address   String?  @db.Text
  spaceId   String   @db.VarChar(30)
  ownerId   String   @db.VarChar(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space     Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  owner     User      @relation(fields: [ownerId], references: [id])
  deals     Deal[]
  prospects Prospect[]
  customers Customer[]
}

// ─── ACTIVITY LOG ───

model ActivityLog {
  id             String   @id @default(cuid()) @db.VarChar(30)
  action         String   @db.VarChar(30)
  entity         String   @db.VarChar(50)
  entityId       String?  @db.VarChar(30)
  details        String?  @db.Text
  changedFields  String?  @db.Text
  previousValues String?  @db.Text
  newValues      String?  @db.Text
  spaceId        String   @db.VarChar(30)
  userId         String   @db.VarChar(30)
  createdAt      DateTime @default(now())

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])
}

// ─── EMAIL SETTINGS ───

model EmailSettings {
  id        String   @id @default(cuid()) @db.VarChar(30)
  host      String   @db.VarChar(255)
  port      Int      @default(465)
  secure    Boolean  @default(true)
  sender    String   @db.VarChar(255)
  user      String   @db.VarChar(255)
  pass      String   @db.VarChar(255)
  userId    String   @unique @db.VarChar(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRel User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── INVITATION ───

model Invitation {
  id        String   @id @default(cuid()) @db.VarChar(30)
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  role      String   @default("viewer") @db.VarChar(20)
  status    String   @default("pending") @db.VarChar(20) // pending | accepted | expired
  expiresAt DateTime
  invitedBy String   @db.VarChar(30)
  spaceId   String   @db.VarChar(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}
